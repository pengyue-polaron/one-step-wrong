# Server-only. Never expose this value through NEXT_PUBLIC_*.
OPENAI_API_KEY=

# Optional canonical origin for production metadata and social previews.
SITE_URL=http://localhost:3000

# Local development only. Requires `codex login`; ignored when NODE_ENV=production.
CODEX_LOCAL_PROVIDER=0
# Optional: use a model slug available to the signed-in Codex account.
CODEX_LOCAL_MODEL=
